---
import PageLayout from "../layouts/PageLayout.astro";
import PersonaPicker from "../components/PersonaPicker.astro";
import ChainMap from "../components/ChainMap.tsx";
---

<PageLayout>
  <main class="prose-column">
    <header class="hero">
      <p class="eyebrow">A visual on-ramp to federal IT compliance</p>
      <h1 class="hero-title">fed it for humans</h1>
      <p class="hero-lede">
        FISMA at the top, STIGs and CIS at the bottom, and a clickable map
        of how the chain actually hangs together. Written for people coming
        into this world cold.
      </p>
    </header>
  </main>

  <section class="wide-column chainmap-section">
    <h2 class="section-heading">The chain</h2>
    <p class="section-sub">
      Click any node to read its chapter. Foundation chain runs top to
      bottom in the center; forks branch off where they apply. Out-of-scope
      forks are marked with dashed borders.
    </p>
    <ChainMap client:load />
  </section>

  <section class="wide-column persona-section">
    <PersonaPicker />
  </section>
</PageLayout>

<style>
  .hero {
    padding-block: var(--space-24) var(--space-8);
    text-align: center;
  }

  .eyebrow {
    text-transform: uppercase;
    letter-spacing: 0.15em;
    font-size: var(--fs-xs);
    color: var(--color-muted);
    margin: 0 0 var(--space-4);
  }

  .hero-title {
    font-size: var(--fs-3xl);
    margin: 0 0 var(--space-4);
    line-height: 1.05;
  }

  .hero-lede {
    font-size: var(--fs-md);
    color: var(--color-muted);
    max-width: 32rem;
    margin: 0 auto;
    line-height: 1.5;
  }

  .chainmap-section {
    padding-block: var(--space-8) var(--space-12);
  }

  .persona-section {
    padding-block: var(--space-8) var(--space-12);
    border-top: 1px solid var(--color-border);
  }

  .section-heading {
    font-size: var(--fs-xl);
    margin: 0 0 var(--space-2);
    text-align: center;
  }

  .section-sub {
    color: var(--color-muted);
    max-width: 36rem;
    margin: 0 auto var(--space-6);
    text-align: center;
    font-size: var(--fs-sm);
  }
</style>
