---
/**
 * WPanel — institutional view of a concept (Who / What / Where / Why / How).
 * The "outside-in" half of The Frame. Same content for every reader.
 *
 * Pair with <YouPanel persona="..."> blocks underneath for the personal layer.
 *
 * SECURITY NOTE: each W field is rendered with `set:html` so authors can
 * include inline links/emphasis in the prop value. This is SAFE only when
 * the content originates from author-controlled source (MDX frontmatter,
 * static prop strings). NEVER pass user-submitted content to these props.
 * If we ever accept user contributions, switch this component to slot-based
 * children so MDX/Astro escape it for us.
 */

interface Props {
  title?: string;
  who: string;
  what: string;
  where: string;
  why: string;
  how: string;
}

const { title, who, what, where, why, how } = Astro.props;

const rows: Array<[string, string]> = [
  ["Who", who],
  ["What", what],
  ["Where", where],
  ["Why", why],
  ["How", how],
];
---

<section class="wpanel" aria-label={title ? `Frame: ${title}` : "The Frame"}>
  {title && <h3 class="wpanel-title">{title}</h3>}
  <dl class="wpanel-grid">
    {rows.map(([label, value]) => (
      <div class="wpanel-row">
        <dt>{label}</dt>
        <dd set:html={value} />
      </div>
    ))}
  </dl>
</section>

<style>
  .wpanel {
    background: var(--color-card);
    border: 1px solid var(--color-border);
    border-left: 4px solid var(--color-accent);
    border-radius: var(--radius);
    padding: var(--space-6);
    margin-block: var(--space-6);
    box-shadow: var(--shadow-sm);
  }

  .wpanel-title {
    margin: 0 0 var(--space-4);
    font-size: var(--fs-md);
    color: var(--color-fg);
  }

  .wpanel-grid {
    display: grid;
    gap: var(--space-3);
    margin: 0;
  }

  .wpanel-row {
    display: grid;
    grid-template-columns: 5rem 1fr;
    gap: var(--space-4);
    align-items: baseline;
  }

  .wpanel-row dt {
    font-family: var(--font-serif);
    font-weight: 600;
    font-size: var(--fs-sm);
    color: var(--color-accent);
    margin: 0;
  }

  .wpanel-row dd {
    margin: 0;
    color: var(--color-fg);
  }

  @media (max-width: 480px) {
    .wpanel-row {
      grid-template-columns: 1fr;
      gap: var(--space-1);
    }
  }
</style>
